# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file. Defaults to symptoms.db in the working dir.
# DB_PATH=symptoms.db

# Path for uploaded profile photos. Defaults to uploads/ in the working dir.
# UPLOAD_DIR=uploads

# ── Secret key ────────────────────────────────────────────────────────────────
# Used to sign session tokens. If not set, a random key is auto-generated and
# saved to .app_secret_key (also gitignored). Set explicitly in production so
# sessions survive restarts.
# APP_SECRET_KEY=

# Public base URL for links sent by email, e.g. password reset and verification.
# Set this in production so outbound links do not depend on request Host headers.
# APP_BASE_URL=https://tracker.example.com

# Comma-separated list of allowed Host headers. Defaults to APP_BASE_URL's host
# when set, otherwise localhost/testserver-only for development.
# ALLOWED_HOSTS=tracker.example.com

# ── Email: SMTP (preferred) ───────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=no-reply@example.com

# ── Email: Mailgun API (fallback if SMTP not configured) ─────────────────────
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=mg.example.com
# MAILGUN_FROM=no-reply@mg.example.com

# ── AI features (optional) ────────────────────────────────────────────────────
# Get your API key at https://console.anthropic.com/
# If not set, AI features are hidden from the UI.
# ANTHROPIC_API_KEY=
